# Main simulation controller (internal lock model).
# The script now uses separate internal locks:
#   - sim_enqueue.lock    (fast STEP_0 enqueue phase)
#   - sim_processing.lock (run_step + housekeeping)
#   - sim_final.lock      (STEP_FINAL owner lock)
# Do not wrap this cron entry in an external flock; that would re-introduce
# enqueue starvation whenever processing is long.
#
# STEP_FINAL ownership policy:
#   - run_main is configured below with SIM_PROCESSING_RUN_STEP_FINAL=0
#   - standalone STEP_FINAL cron is the sole owner (next line)
# This avoids duplicate STEP_FINAL attempts and repetitive lock-busy noise.
# Optional alert wiring (for run_step persistent stuck/broken alerts):
#   - set SIM_ALERT_TELEGRAM_CHAT_IDS="id1,id2" inline below, or
#   - populate OPERATIONS/OPERATIONS_SCRIPTS/NOTIFICATIONS/TELEGRAM_BOT/ALERT_CHAT_IDS.txt
* * * * * /bin/bash $HOME/DATAFLOW_v3/OPERATIONS/OPERATIONS_SCRIPTS/ORCHESTRATION/CRON_RUN_LOGGED/cron_run_logged.sh $HOME/DATAFLOW_v3/OPERATIONS/OPERATIONS_RUNTIME/CRON_LOGS/SIMULATION/RUN/sim_main_pipeline_cycle.log -- SIM_PROCESSING_RUN_STEP_FINAL=0 /bin/bash $HOME/DATAFLOW_v3/MINGO_DIGITAL_TWIN/ORCHESTRATOR/core/run_main_simulation_cycle.sh
* * * * * /bin/bash $HOME/DATAFLOW_v3/OPERATIONS/OPERATIONS_SCRIPTS/ORCHESTRATION/CRON_RUN_LOGGED/cron_run_logged.sh $HOME/DATAFLOW_v3/OPERATIONS/OPERATIONS_RUNTIME/CRON_LOGS/SIMULATION/STEP_FINAL/step_final_cron.log -- /usr/bin/flock -n $HOME/DATAFLOW_v3/OPERATIONS/OPERATIONS_RUNTIME/LOCKS/cron/sim_final.lock /usr/bin/env python3 $HOME/DATAFLOW_v3/MINGO_DIGITAL_TWIN/MASTER_STEPS/STEP_FINAL/step_final_daq_to_station_dat.py --config $HOME/DATAFLOW_v3/MINGO_DIGITAL_TWIN/MASTER_STEPS/STEP_FINAL/config_step_final_physics.yaml

# Ensure simulation hashes (daily, serialized with processing phase).
25 6 * * * /bin/bash $HOME/DATAFLOW_v3/OPERATIONS/OPERATIONS_SCRIPTS/ORCHESTRATION/CRON_RUN_LOGGED/cron_run_logged.sh $HOME/DATAFLOW_v3/OPERATIONS/OPERATIONS_RUNTIME/CRON_LOGS/ANCILLARY/ensure_sim_hashes.log -- /usr/bin/flock -n $HOME/DATAFLOW_v3/OPERATIONS/OPERATIONS_RUNTIME/LOCKS/cron/sim_processing.lock /usr/bin/env python3 $HOME/DATAFLOW_v3/MINGO_DIGITAL_TWIN/ORCHESTRATOR/maintenance/sim_maintenance.py ensure-hashes --apply --run-validate-quick


