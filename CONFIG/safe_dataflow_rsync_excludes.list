# Safe mirror policy:
# Keep source code, configs, docs, and lightweight operational scripts.
# Exclude generated data, local environments, caches, logs, archives, and
# simulation/analysis products. The daily cron rsync in CONFIG/add_to_crontab.info
# uses this file to populate $HOME/SAFE_DATAFLOW_v3.

# Repository/runtime internals
.git/
.gitignore
.agents/
.codex/
.pytest_cache/
.venv/
.vscode/
OPERATIONS/OPERATIONS_RUNTIME/

# Top-level data/archive trees that should not be mirrored
.ATTIC/
OPERATIONS/OPERATIONS_RUNTIME/REMOTE_LOG_BACKUP/hosts/
OPERATIONS/OPERATIONS_RUNTIME/REMOTE_LOG_BACKUP/
MINGO_ANALYSIS/MINGO_ANALYSIS_STATIONS/
VARIOUS/
SIMULATION_DATA_JUNK/
STATIONS_FEB_26/

# Generated outputs / figures / plots / logs
**/.ATTIC/***
**/OUTPUT/***
**/OUTPUTS/***
**/OUTPUT_FILES/***
**/PLOTS/***
**/FIGURES/***
**/LOGS/***
**/logs/***
**/NMDB/***
**/__pycache__/***
**/.pytest_cache/***
**/.ipynb_checkpoints/***

# Digital twin generated data and archived simulation outputs
MINGO_DIGITAL_TWIN/.ATTIC/
MINGO_DIGITAL_TWIN/SIMULATION_OUTPUTS/INTERSTEPS/
MINGO_DIGITAL_TWIN/SIMULATION_OUTPUTS/SIMULATED_DATA/
MINGO_DIGITAL_TWIN/VALIDATION/output/
MINGO_DIGITAL_TWIN/PLOTTERS/EXECUTION/OUTPUT_FILES/
MINGO_DIGITAL_TWIN/PLOTTERS/EXECUTION/MESH/OUTPUT_FILES/
MINGO_DIGITAL_TWIN/PLOTTERS/STEPS/OUTPUT_FILES/

# Bundled unpacker runtime data/logs. Keep the unpacker source, skip raw/runtime
# detector dumps and generated runtime state.
MINGO_ANALYSIS/MINGO_ANALYSIS_SCRIPTS/STAGES/STAGE_0/REPROCESSING/UNPACKER_ZERO_STAGE_FILES/system/
**/rawData/***

# Known standalone generated data files outside output trees
QUICK_TEST/*.csv

# Heavy generated files that do not belong in the safe code mirror
*.log
*.out
*.err
*.parquet
*.feather
*.root
*.h5
*.hdf5
*.npy
*.npz
*.pkl
*.pickle
*.png
*.jpg
*.jpeg
*.JPG
*.JPEG
*.pdf
*.PDF
*.svg
*.SVG
*.eps
*.EPS
*.ps
*.PS
*.mat
*.MAT
*.hld
*.HLD
